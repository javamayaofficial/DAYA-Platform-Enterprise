APP_NAME=DAYA Platform
APP_ENV=development
APP_DEBUG=1
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta
APP_INSTALLED=0
APP_KEY=

SESSION_NAME=daya_session
SESSION_LIFETIME=120
SESSION_SECURE=0
SESSION_HTTP_ONLY=1
SESSION_SAME_SITE=Lax

AUTH_MAIL_MODE=log
AUTH_MAIL_FROM=no-reply@daya.local
AUTH_REMEMBER_COOKIE=daya_remember

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4
