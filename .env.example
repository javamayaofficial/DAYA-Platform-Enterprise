APP_NAME=DAYA Platform
APP_ENV=production
APP_DEBUG=0
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Jakarta
APP_INSTALLED=0
APP_KEY=
APP_LOG_LEVEL=info

SESSION_NAME=daya_session
SESSION_LIFETIME=120
SESSION_SECURE=1
SESSION_HTTP_ONLY=1
SESSION_SAME_SITE=Lax

SECURITY_HEADERS_ENABLED=1
SECURITY_HSTS_ENABLED=0
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_FRAME_OPTIONS=SAMEORIGIN
SECURITY_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=()
SECURITY_CROSS_DOMAIN_POLICIES=none

AUTH_MAIL_MODE=log
AUTH_MAIL_FROM=no-reply@daya.local
AUTH_MAILKETING_ENDPOINT=https://api.mailketing.co.id/api/v1/send
AUTH_MAILKETING_API_TOKEN=
AUTH_MAILKETING_FROM_NAME=DAYA Platform
AUTH_MAILKETING_FROM_EMAIL=no-reply@your-domain.com
AUTH_MAILKETING_TIMEOUT=15
AUTH_REMEMBER_COOKIE=daya_remember

WHATSAPP_MODE=off
WHATSAPP_DEFAULT_COUNTRY_CODE=62
WHATSAPP_ADMIN_TARGETS=
WHATSAPP_EVENT_ADMIN_CREATOR_REGISTRATION=1
WHATSAPP_EVENT_ADMIN_CREATOR_REVIEW=1
WHATSAPP_FONNTE_ENDPOINT=https://api.fonnte.com/send
WHATSAPP_FONNTE_TOKEN=
WHATSAPP_FONNTE_TIMEOUT=15
WHATSAPP_FONNTE_TYPING=0
WHATSAPP_FONNTE_CONNECT_ONLY=1

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4
